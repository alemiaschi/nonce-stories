    "reuse_curve": {
      "description": "Target fraction of nonce lemmas in each new story that should be drawn from the existing lexicon (not newly invented). This is a guideline, not a hard rule — individual stories may vary. Lower reuse = more new vocabulary, higher reuse = denser cross-referencing. The curve shifts upward as the project matures and the lexicon grows.",
      "1": 0.65,
      "2": 0.7,
      "3": 0.75,
      "4": 0.8,
      "5": 0.85,
      "6": 0.9,
      "leaf": 0.95,
      "adjustment_note": "These are starting values. Alessio adjusts as the project evolves. Early phase favors lower reuse (more world-building). Later phases favor higher reuse (denser semantic web, faster reader comprehension)."
    },
    "morphological_rules": {
      "inflectional": {
        "noun_plural": {
          "rule": "-en after consonant, -ren after vowel",
          "examples": [
            "brolm → brolmen",
            "velune → veluneren"
          ]
        },
        "noun_possessive": {
          "rule": "-is",
          "examples": [
            "brolm → brolmis",
            "velune → veluneis",
            "crullen → crullenis"
          ]
        },
        "verb_past": {
          "rule": "-ara after consonant, -ra after vowel; English -ed also permitted for euphony",
          "examples": [
            "quelm → quelmara",
            "tremique → tremiquera",
            "melvir → melvired"
          ]
        },
        "verb_participle": {
          "rule": "-ith (formal) or English -ing (when used with English auxiliaries)",
          "examples": [
            "quelm → quelmith",
            "thendara → thendaraing",
            "zandique → zandiqueing"
          ]
        },
        "verb_3rd_singular": {
          "rule": "-et",
          "examples": [
            "quelm → quelmet",
            "vriso → vrisoet"
          ]
        },
        "adj_comparative": {
          "rule": "-un",
          "examples": [
            "thengar → thengarun"
          ]
        },
        "adj_superlative": {
          "rule": "-est",
          "examples": [
            "thengar → thengarest"
          ]
        },
        "adj_adverb": {
          "rule": "-elu (formal) or English -ly (for readability)",
          "examples": [
            "thengar → thengarelu",
            "janvire → janvirely"
          ]
        }
      },
      "derivational": {
        "noun_to_adj": {
          "rule": "-ik",
          "examples": [
            "brolm → brolmik"
          ]
        },
        "verb_to_noun_act": {
          "rule": "-om",
          "examples": [
            "pellum → pellumom"
          ]
        },
        "adj_to_noun_quality": {
          "rule": "-ath",
          "examples": [
            "thengar → thengarath"
          ]
        }
      },
      "notes": "Zero-derivation (conversion) is permitted: a noun may be used verbally or an adjective may be used nominally, following natural English patterns. When nonce morphology would create unpronounceable clusters, English-style inflection (-ed, -ing, -ly) is preferred."
    },
